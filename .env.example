POSTGRES_DB=comment_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/comment_analytics

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

DEMO_MODE=false
BACKGROUND_JOBS_ENABLED=false
INGESTION_BATCH_SIZE=25
DEFAULT_LOOKBACK_DAYS=90
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
PROVIDER_HTTP_TIMEOUT_SECONDS=30

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

VK_API_TOKEN=
VK_API_VERSION=5.199
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=high
OPENAI_PROMPT_ROUTER_MODEL=gpt-4.1-mini
OPENAI_PROMPT_ROUTER_MAX_COMPLETION_TOKENS=160
OPENAI_COMMENT_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_COMMENT_ANALYSIS_REASONING_EFFORT=low
LLM_SUMMARY_ENABLED=false
LLM_COMMENT_ANALYSIS_ENABLED=true
LLM_COMMENT_ANALYSIS_BATCH_SIZE=10
LLM_COMMENT_ANALYSIS_MAX_COMPLETION_TOKENS=700
LLM_COMMENT_ANALYSIS_CACHE_TTL_SECONDS=2592000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
